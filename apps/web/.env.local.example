# Astronomy API Configuration
# Get your free API key from https://astronomyapi.com
# Sign up and create an application to get these credentials

NEXT_PUBLIC_ASTRONOMY_API_ID=your_application_id_here
NEXT_PUBLIC_ASTRONOMY_API_SECRET=your_application_secret_here

# Note: The Astronomy API is currently used as a fallback for constellation data
# The app will work without these credentials using local constellation data

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Gemini AI API Configuration (for generating celestial object info)
# Get your API key from https://makersuite.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Note: Without Gemini API key, the app will use hardcoded fallback data
# for constellation info. With the API key, info will be generated on-demand
# and cached in the database for future use.
