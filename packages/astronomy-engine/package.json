{
  "name": "@virtual-window/astronomy-engine",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:constellations": "tsx scripts/generate-constellations.ts",
    "copy:constellations": "cp data/constellations.json ../../apps/web/public/data/constellations.json",
    "update:constellations": "npm run generate:constellations && npm run copy:constellations"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
